# ==============================================================
# AI Tutor V5.1 - Environment template
# ==============================================================
# Copy this file to .env and set real values.

# Required for Gemini calls (Phase 3).
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# LLM provider selection: ollama | gemini
LLM_PROVIDER=ollama

# Model names
OLLAMA_MODEL=qwen2.5
GEMINI_MODEL=gemini-1.5-flash

# Core paths
DB_PATH=data/ai_tutor_v5.db
FAISS_INDEX_PATH=vector_store/faiss_index.bin
LOG_PATH=logs/app.log

# Chunking and retrieval knobs
# CHUNK_SIZE must stay in [256, 512] per spec.
CHUNK_SIZE=256
CHUNK_OVERLAP=50
TOP_K=3

# Embedding model (default from spec)
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# Optional: print top retrieved chunks to logs for debugging RAG quality.
DEBUG_RAG_CONTEXT=false
