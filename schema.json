{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GeneratedQuestion",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "question_id",
    "content",
    "difficulty",
    "subject",
    "options",
    "answer",
    "explanation"
  ],
  "properties": {
    "question_id": {
      "type": "integer",
      "minimum": 1
    },
    "content": {
      "type": "string",
      "minLength": 1
    },
    "difficulty": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },
    "subject": {
      "type": "string",
      "minLength": 1
    },
    "options": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "answer": {
      "type": "string",
      "enum": ["A", "B", "C", "D"]
    },
    "explanation": {
      "type": "string",
      "minLength": 1
    }
  }
}
